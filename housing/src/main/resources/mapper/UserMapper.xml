<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.house.housing.mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.house.housing.entity.User">
        <id column="id" property="id"/>
        <result column="real_name" property="realName"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <select id="selectUserList" resultMap="UserResultMap">
        SELECT *
        FROM users
        <where>
            <if test="query.role != null">
                AND role = #{query.role}
            </if>
            <if test="query.status != null">
                AND status = #{query.status}
            </if>
            <if test="query.keyword != null and query.keyword != ''">
                AND (username LIKE CONCAT('%', #{query.keyword}, '%')
                OR phone LIKE CONCAT('%', #{query.keyword}, '%')
                OR real_name LIKE CONCAT('%', #{query.keyword}, '%'))
            </if>
        </where>
        ORDER BY created_at DESC
        LIMIT #{query.limit} OFFSET #{query.offset}
    </select>

    <select id="countUserList" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM users
        <where>
            <if test="query.role != null">
                AND role = #{query.role}
            </if>
            <if test="query.status != null">
                AND status = #{query.status}
            </if>
            <if test="query.keyword != null and query.keyword != ''">
                AND (username LIKE CONCAT('%', #{query.keyword}, '%')
                OR phone LIKE CONCAT('%', #{query.keyword}, '%')
                OR real_name LIKE CONCAT('%', #{query.keyword}, '%'))
            </if>
        </where>
    </select>

    <resultMap id="RoleCountMap" type="com.house.housing.vo.RoleCountVO">
        <result column="role" property="role"/>
        <result column="count" property="count"/>
    </resultMap>

</mapper>